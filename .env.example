# Supabase project credentials (Settings → API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Service-role key (Settings → API → service_role, "secret" section).
# Required for "Copy invite link" and any other Auth Admin API call.
# Server-only -- never expose with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET-KEY

# Canonical site URL used to build invite/reset-password redirect links.
# Falls back to VERCEL_URL, then a hardcoded default, if unset.
NEXT_PUBLIC_SITE_URL=https://vantage-ag.vercel.app
